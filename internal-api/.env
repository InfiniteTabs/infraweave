# AWS Configuration
REGION=us-west-2
CLOUD_PROVIDER=aws

# DynamoDB Tables
DYNAMODB_EVENTS_TABLE_NAME=infraweave-events
DYNAMODB_MODULES_TABLE_NAME=infraweave-modules
DYNAMODB_POLICIES_TABLE_NAME=infraweave-policies
DYNAMODB_DEPLOYMENTS_TABLE_NAME=infraweave-deployments
DYNAMODB_CHANGE_RECORDS_TABLE_NAME=infraweave-change-records
DYNAMODB_CONFIG_TABLE_NAME=infraweave-config

# S3 Buckets
MODULE_S3_BUCKET=infraweave-modules
POLICY_S3_BUCKET=infraweave-policies
CHANGE_RECORD_S3_BUCKET=infraweave-change-records
PROVIDERS_S3_BUCKET=infraweave-providers

# Account & Environment
ENVIRONMENT=dev
CENTRAL_ACCOUNT_ID=000000000000
CURRENT_ACCOUNT_ID=000000000000

# Notifications & Observability
NOTIFICATION_TOPIC_ARN=arn:aws:sns:us-west-2:000000000000:infraweave-notifications
AWS_XRAY_CONTEXT_MISSING=LOG_ERROR

# AWS Credentials (will use your default AWS profile if not set)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token
